# Copy this file to .env and fill in your values

# Supabase PostgreSQL — use Session Pooler URL from your Supabase dashboard
# https://supabase.com/dashboard/project/<ref>/settings/database
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<password>@<host>.pooler.supabase.com:5432/postgres

# Google Gemini API Key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — swap here if quota is exhausted
# Options: gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# Supabase anon/publishable key (optional — for future REST API use)
SUPABASE_API_KEY=your_supabase_anon_key_here
